# ── Terminal 3 Dev Sandbox ─────────────────────────
# Get sandbox token from claim page: https://www.terminal3.io/claim-page
# NOTE: the SDK (board/src/sdk/T3nClient.ts) reads T3_API_KEY (or NEXT_PUBLIC_T3_API_KEY).
T3_API_KEY=0x_your_terminal3_api_key_here

# ── Wallet (RainbowKit / WalletConnect) ───────────
# Free projectId from https://cloud.reown.com — enables the WalletConnect relay
# (QR + mobile wallets). Injected wallets (MetaMask) work without it.
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# ── Durable state (Vercel KV / Upstash Redis) ─────
# Serverless functions are stateless, so milestone state is persisted to a KV.
# Provision a free KV in Vercel (Storage → Upstash for Redis); it auto-injects
# KV_REST_API_URL / KV_REST_API_TOKEN. Without these, state is in-memory only
# (fine for local dev; NOT reliable on serverless). UPSTASH_REDIS_REST_* also work.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Server Config ──────────────────────────────────
# Default local port for dashboard and SDK calls
PORT=3000
NODE_ENV=development
