# Terminal 3 Agent Auth SDK Token
# You can claim your tokens at: https://www.terminal3.io/claim-page
T3_API_KEY=0x_your_terminal3_api_key_here

# ── Web3 Connection (RainbowKit / WalletConnect) ──────────────
# Required to avoid localhost block errors and enable mobile QR login
# Get from: https://cloud.reown.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=